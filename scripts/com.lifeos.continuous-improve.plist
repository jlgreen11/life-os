<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.lifeos.continuous-improve</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/jeremygreenwood/life-os/scripts/run-continuous-improvement.sh</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/jeremygreenwood/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>/Users/jeremygreenwood</string>
    </dict>
    <key>WorkingDirectory</key>
    <string>/Users/jeremygreenwood/life-os</string>
    <!-- KeepAlive: restart the script if it ever exits (crash, OOM, etc.) -->
    <key>KeepAlive</key>
    <true/>
    <!-- Throttle restarts: wait at least 30 seconds between launches to avoid
         rapid restart loops if the script fails immediately on startup. -->
    <key>ThrottleInterval</key>
    <integer>30</integer>
    <key>StandardOutPath</key>
    <string>/Users/jeremygreenwood/life-os/data/improvement-runs/continuous-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jeremygreenwood/life-os/data/improvement-runs/continuous-stderr.log</string>
</dict>
</plist>
